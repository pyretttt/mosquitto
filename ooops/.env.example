# Copy to .env and edit. docker compose picks .env up automatically.

# GitLab external URL. Keep in sync with the compose port mapping.
GITLAB_EXTERNAL_URL=http://localhost:8080

# Grafana admin creds (change on first login in the UI).
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# MLflow tracking URI, as seen *from inside* the ml-app container.
MLFLOW_TRACKING_URI=http://mlflow:5000

# MLflow experiment name used by training jobs.
MLFLOW_EXPERIMENT_NAME=iris-classifier

# Name of the registered model (for the Model Registry exercise).
ML_MODEL_NAME=iris-classifier
ML_MODEL_STAGE=None
