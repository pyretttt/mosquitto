# Copy to .env and adjust. Never commit real tokens or unseal keys.
#
# For `mise run vault-dev`, a fixed root token keeps demos simple:

VAULT_DEV_ROOT_TOKEN=root
VAULT_ADDR=http://127.0.0.1:8200

# Optional: after init of file-storage Vault, you may export:
# VAULT_TOKEN=

CLUSTER_NAME=vault-lab
NS_VAULT=vault
NS_APP=demo
