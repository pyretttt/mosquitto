# TODO(you): create a real Secret for the demo app — see TASKS.md §1
#   Option A: kubectl create secret generic demo-app-secret ...
#   Option B: copy this file, fill stringData, apply (keep *.plain.yaml out of git)
apiVersion: v1
kind: Secret
metadata:
  name: demo-app-secret
  namespace: demo
  labels:
    app.kubernetes.io/name: demo-app
type: Opaque
stringData:
  # stringData is convenience — API server stores base64 in .data
  API_TOKEN: "replace-me"
  DB_PASSWORD: "replace-me"
