{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "title": "Triton Inference",
  "tags": ["triton", "little-ml-story"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-15m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Inference count (per model)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (model) (rate(nv_inference_count[1m]))",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Avg request duration (us)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum by (model) (rate(nv_inference_request_duration_us[5m])) / sum by (model) (rate(nv_inference_request_success[5m]))",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "µs"}}
    },
    {
      "id": 3,
      "title": "Queue duration (us)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum by (model) (rate(nv_inference_queue_duration_us[5m])) / sum by (model) (rate(nv_inference_request_success[5m]))",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "µs"}}
    }
  ]
}
